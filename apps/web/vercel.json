{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm -r --filter \"./packages/*\" build && pnpm --filter web build",
  "crons": [
    {
      "path": "/api/cron/regenerate",
      "schedule": "0 6 * * *"
    }
  ]
}
