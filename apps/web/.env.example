# Postgres (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Canonical public URL for SEO/GEO surfaces (no trailing slash)
NEXT_PUBLIC_SITE_URL=margot.vercel.app

# Google OAuth (Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Inngest (cloud or local dev server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe
# Monthly is required; annual is optional. If STRIPE_PRICE_ID_ANNUAL is unset
# the billing page hides the annual option and only offers monthly.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Vercel Cron secret (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Encryption key for OAuth refresh tokens at rest (32 bytes base64)
TOKEN_ENCRYPTION_KEY=

# OpenRouteService API key for real drive durations (free tier 2,000 req/day).
# When unset, travel blocks fall back to the configured fallback duration.
OPENROUTESERVICE_API_KEY=

# Preview-only auto-login. Activates ONLY when ALL three conditions hold:
#   1. VERCEL_ENV === "preview" (Vercel sets this automatically; never "preview" in production)
#   2. PREVIEW_AUTH_ENABLED === "true" (explicit opt-in)
#   3. PREVIEW_AUTH_USER_EMAIL is set to an existing user email in the DB
# Configure these on Vercel Project Settings → Environment Variables with the
# "Preview" environment selected only. Leaving them on Production has no effect
# because the VERCEL_ENV guard short-circuits, but for least-privilege scope
# them to Preview anyway.
PREVIEW_AUTH_ENABLED=false
PREVIEW_AUTH_USER_EMAIL=