# Postgres (Neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Canonical public URL for SEO/GEO surfaces (no trailing slash)
NEXT_PUBLIC_SITE_URL=calendar-automations.vercel.app

# Google OAuth (Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Inngest (cloud or local dev server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Vercel Cron secret (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Encryption key for OAuth refresh tokens at rest (32 bytes base64)
TOKEN_ENCRYPTION_KEY=
