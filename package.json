{
  "name": "margot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./apps/*\" build",
    "dev": "pnpm --filter web dev",
    "test": "pnpm -r --filter \"./packages/*\" test && pnpm --filter web test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter web db:generate",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
